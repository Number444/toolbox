<UserControl x:Class="Toolbox.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:Toolbox.Core.Services;assembly=Toolbox.Core">
    <StackPanel Margin="32,16">
        <!-- 标题 + 返回按钮 -->
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackButton" Content="← 返回工具箱"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    Padding="12,6"
                    FontSize="13"
                    Cursor="Hand"
                    Click="BackButton_Click"/>
            <TextBlock Grid.Column="1" Text="设置" FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" Margin="16,0,0,0"/>
        </Grid>

        <!-- 分隔线 -->
        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}" Margin="0,0,0,20"/>

        <!-- 设置项卡片 -->
        <Border Background="{StaticResource BgSurfaceBrush}"
                CornerRadius="8"
                Padding="16,14"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1">
            <StackPanel>
                <CheckBox x:Name="MinimizeCheckBox"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Content="关闭按钮最小化到任务栏"
                          IsChecked="{Binding Source={x:Static services:AppSettings.Instance}, Path=MinimizeOnClose, Mode=TwoWay}"
                          Margin="0,0,0,8"/>
                <TextBlock Text="勾选后点击关闭按钮会将 Toolbox 收入任务栏而非退出程序。"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>

                <!-- 启动时自动打开悬浮窗 -->
                <CheckBox x:Name="AutoOpenCheckBox"
                          Style="{StaticResource ToggleSwitchStyle}"
                          Content="启动时自动打开悬浮窗"
                          IsChecked="{Binding Source={x:Static services:AppSettings.Instance}, Path=AutoOpenFloatWindow, Mode=TwoWay}"
                          Margin="0,16,0,0"/>

                <!-- 悬浮窗默认大小 -->
                <WrapPanel Margin="0,16,0,0">
                    <TextBlock Text="悬浮窗默认大小："
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               Margin="0,0,8,0"/>
                    <ComboBox SelectedValue="{Binding Source={x:Static services:AppSettings.Instance}, Path=MusicFloatSizeMode, Mode=TwoWay}"
                              SelectedValuePath="Tag"
                              Width="120"
                              FontSize="13">
                        <ComboBoxItem Tag="Large" Content="大模式"/>
                        <ComboBoxItem Tag="Compact" Content="紧凑模式"/>
                    </ComboBox>
                </WrapPanel>

                <!-- 开机自启（滑块开关） -->
                <CheckBox Content="开机自动启动 Toolbox"
                          Style="{StaticResource ToggleSwitchStyle}"
                          IsChecked="{Binding Source={x:Static services:AppSettings.Instance}, Path=AutoStart, Mode=TwoWay}"
                          Margin="0,16,0,0"/>

                <!-- 鼠标光晕（滑块开关） -->
                <CheckBox Content="鼠标跟随光晕"
                          Style="{StaticResource ToggleSwitchStyle}"
                          IsChecked="{Binding Source={x:Static services:AppSettings.Instance}, Path=MouseHaloEnabled, Mode=TwoWay}"
                          Margin="0,16,0,0"/>

                <!-- 控件边缘发光（滑块开关） -->
                <CheckBox Content="控件边缘发光（鼠标照亮效果）"
                          Style="{StaticResource ToggleSwitchStyle}"
                          IsChecked="{Binding Source={x:Static services:AppSettings.Instance}, Path=ControlGlowEnabled, Mode=TwoWay}"
                          Margin="0,16,0,0"/>
            </StackPanel>
        </Border>

        <!-- 退出按钮 -->
        <Button x:Name="ExitButton" Content="退出 Toolbox"
                Background="{StaticResource DangerBrush}"
                Foreground="White"
                HorizontalAlignment="Left"
                Margin="0,24,0,0"
                Padding="16,8"
                FontSize="14"
                Cursor="Hand"
                Click="ExitButton_Click"/>
    </StackPanel>
</UserControl>