<UserControl x:Class="Toolbox.Controls.MusicContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="RootGrid">
    <StackPanel x:Name="ContentPanel"
                Background="Transparent"
                Opacity="1"
                Margin="0">

        <!-- 形态 A：大模式（默认可见） -->
        <StackPanel x:Name="LayoutLarge" Visibility="Visible">

            <!-- 封面 + DropShadowEffect -->
            <Grid x:Name="CoverGrid" Width="180" Height="180"
                  HorizontalAlignment="Center"
                  Margin="12,12,12,0"
                  RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="CoverScaleTransform"
                                    ScaleX="1" ScaleY="1"/>
                </Grid.RenderTransform>
                <Border x:Name="CoverContainer"
                        CornerRadius="10">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15"
                                          ShadowDepth="4"
                                          Opacity="0.5"
                                          Color="Black" />
                    </Border.Effect>
                    <Grid x:Name="CoverClipContainer">
                        <Grid.Clip>
                            <RectangleGeometry RadiusX="10" RadiusY="10"
                                Rect="0,0,180,180" />
                        </Grid.Clip>
                        <!-- CoverImageBack 承载旧封面，交叉淡入期间可见 -->
                        <Image x:Name="CoverImageBack"
                               Stretch="UniformToFill" />
                        <!-- CoverImage 承载新封面 -->
                        <Image x:Name="CoverImage"
                               Stretch="UniformToFill" />
                    </Grid>
                </Border>

                <!-- 悬停播放控制（默认隐藏）。默认在封面内（大模式）；
                     紧凑模式由 ApplySizeMode 移到根容器整窗居中 -->
                <Border x:Name="PlaybackControls"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="#A6F0F0F0"
                        BorderBrush="#1A000000"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="10,8"
                        Opacity="0"
                        IsHitTestVisible="False">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BtnPrev" Width="30" Height="30" CornerRadius="6"
                                Background="Transparent" Margin="0,0,8,0" Cursor="Hand">
                            <Path Data="M18 6l-8.5 6L18 18z M6 6h2v12H6z"
                                  Fill="#E82D2D2D" Stretch="Uniform" Width="13" Height="13"/>
                        </Border>
                        <Border x:Name="BtnPlayPause" Width="40" Height="40" CornerRadius="8"
                                Background="#E82D2D2D" Cursor="Hand">
                            <Grid>
                                <Path x:Name="PlayIcon" Data="M8 5v14l11-7z"
                                      Fill="#F0F0F0" Stretch="Uniform" Width="16" Height="16"/>
                                <Path x:Name="PauseIcon" Data="M6 5h4v14H6z M14 5h4v14h-4z"
                                      Fill="#F0F0F0" Stretch="Uniform" Width="15" Height="15"
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <Border x:Name="BtnNext" Width="30" Height="30" CornerRadius="6"
                                Background="Transparent" Margin="8,0,0,0" Cursor="Hand">
                            <Path Data="M6 6l8.5 6L6 18z M16 6h2v12h-2z"
                                  Fill="#E82D2D2D" Stretch="Uniform" Width="13" Height="13"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 歌曲标题（支持超长歌名自动缓慢滚动，两端 OpacityMask 渐隐） -->
            <Canvas x:Name="TitleCanvas"
                    Width="220"
                    Height="24"
                    ClipToBounds="True"
                    HorizontalAlignment="Center"
                    Margin="12,8,12,0">
                <Canvas.OpacityMask>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="Black" Offset="0.07"/>
                        <GradientStop Color="Black" Offset="0.93"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Canvas.OpacityMask>
                <TextBlock x:Name="SongTitle"
                           Text="未在播放"
                           Foreground="#FFFFFF"
                           FontSize="15"
                           FontWeight="Bold"
                           TextTrimming="None"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Height="24"
                           Width="220">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="TitleTranslate" X="0" />
                    </TextBlock.RenderTransform>
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="6"
                            ShadowDepth="1"
                            Opacity="0.6"
                            Color="Black" />
                    </TextBlock.Effect>
                </TextBlock>
            </Canvas>

            <!-- 歌手 -->
            <TextBlock x:Name="SongArtist"
                       Text="—"
                       Foreground="#CCCCCC"
                       FontSize="12"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="12,2,12,12">
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="5"
                        ShadowDepth="1"
                        Opacity="0.5"
                        Color="Black" />
                </TextBlock.Effect>
            </TextBlock>

        </StackPanel>

        <!-- 形态 B：紧凑模式 -->
        <Grid x:Name="LayoutCompact" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="CompactCoverSlot" Grid.Column="0"/>
            <StackPanel x:Name="CompactTextSlot" Grid.Column="1"
                        VerticalAlignment="Center"/>
        </Grid>

    </StackPanel>
    </Grid>
</UserControl>