<Window x:Class="Toolbox.Tools.Views.MusicFloatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="网易云音乐"
        Width="252"
        Height="292"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="OnDragAreaMouseDown"
        LocationChanged="OnWindowLocationChanged">

    <!--
        移除 AllowsTransparency="True"，改用 WindowChrome。
        原因：DWM 的 Acrylic/Mica 系统效果无法在分层窗口（WS_EX_LAYERED）上正常工作。
        WindowChrome 替代 AllowsTransparency 实现无边框窗口，同时保留非分层窗口，
        让 DWM 可以正确合成 Acrylic 效果。
    -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      NonClientFrameEdges="None"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="ContentRoot">
        <!-- 传统半透明遮罩（不启用 Acrylic 时使用） -->
        <Border x:Name="OpacityOverlay"
                Background="#731A1A1A"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="4"
                Visibility="Collapsed" />

        <!-- Acrylic 轻量着色层（Acrylic 模式启用时覆盖全窗，最小非零 alpha 确保 WPF 不会跳过渲染） -->
        <Border x:Name="AcrylicTintOverlay"
                Background="#01FFFFFF"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="4"
                IsHitTestVisible="False"
                Visibility="Collapsed" />

        <StackPanel x:Name="ContentPanel"
                    Opacity="1"
                    Margin="0">

            <!-- 形态 A：大模式（原样，默认可见） -->
            <StackPanel x:Name="LayoutLarge" Visibility="Visible">

                <!-- 封面 + DropShadowEffect -->
                <Grid x:Name="CoverGrid" Width="180" Height="180"
                      HorizontalAlignment="Center"
                      Margin="12,12,12,0">
                    <Border x:Name="CoverContainer"
                            CornerRadius="10">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15"
                                              ShadowDepth="4"
                                              Opacity="0.5"
                                              Color="Black" />
                        </Border.Effect>
                        <Grid x:Name="CoverClipContainer">
                            <Grid.Clip>
                                <RectangleGeometry RadiusX="10" RadiusY="10"
                                    Rect="0,0,180,180" />
                            </Grid.Clip>
                            <!-- CoverImageBack 承载旧封面，交叉淡入期间可见 -->
                            <Image x:Name="CoverImageBack"
                                   Stretch="UniformToFill" />
                            <!-- CoverImage 承载新封面，Opactiy 动画 0→1 实现淡入 -->
                            <Image x:Name="CoverImage"
                                   Stretch="UniformToFill" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- 歌曲标题（支持超长歌名自动缓慢滚动） -->
                <Canvas x:Name="TitleCanvas"
                        Width="220"
                        Height="24"
                        ClipToBounds="True"
                        HorizontalAlignment="Center"
                        Margin="12,8,12,0">
                    <TextBlock x:Name="SongTitle"
                               Text="未在播放"
                               Foreground="#FFFFFF"
                               FontSize="15"
                               FontWeight="Bold"
                               TextTrimming="None"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Height="24"
                               Width="220">
                        <TextBlock.RenderTransform>
                            <TranslateTransform x:Name="TitleTranslate" X="0" />
                        </TextBlock.RenderTransform>
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="6"
                                ShadowDepth="1"
                                Opacity="0.6"
                                Color="Black" />
                        </TextBlock.Effect>
                    </TextBlock>
                </Canvas>

                <!-- 歌手 -->
                <TextBlock x:Name="SongArtist"
                           Text="—"
                           Foreground="#CCCCCC"
                           FontSize="12"
                           TextAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="12,2,12,12">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="5"
                            ShadowDepth="1"
                            Opacity="0.5"
                            Color="Black" />
                    </TextBlock.Effect>
                </TextBlock>

            </StackPanel>

            <!-- 形态 B：紧凑模式（新增骨架，默认隐藏） -->
            <Grid x:Name="LayoutCompact" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="CompactCoverSlot" Grid.Column="0"/>
                <StackPanel x:Name="CompactTextSlot" Grid.Column="1"
                            VerticalAlignment="Center"/>
            </Grid>

        </StackPanel>
    </Grid>
</Window>