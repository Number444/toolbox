<Window x:Class="Toolbox.Tools.Views.AcrylicMusicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Toolbox.Controls"
        Title="网易云音乐"
        Width="242"
        Height="252"
        WindowStyle="None"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0"
                      ResizeBorderThickness="0"
                      GlassFrameThickness="0"
                      CornerRadius="0"
                      NonClientFrameEdges="None"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid x:Name="ContentRoot">
        <Border x:Name="OpacityOverlay"
                Background="#731A1A1A"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="4"
                Visibility="Collapsed" />

        <Border x:Name="AcrylicTintOverlay"
                Background="#01FFFFFF"
                CornerRadius="10"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Margin="4"
                IsHitTestVisible="False"
                Visibility="Visible" />

        <controls:MusicContentControl x:Name="MusicContent" />

        <!-- 贴边触发条（默认隐藏，Docked 状态时才可见） -->
        <controls:DockTriggerBar x:Name="DockTriggerBar"
            Width="14"
            VerticalAlignment="Stretch"
            Visibility="Collapsed" />
    </Grid>
</Window>