<Window x:Class="Toolbox.Tools.Views.TransparentMusicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Toolbox.Controls"
        Title="网易云音乐"
        Width="242"
        Height="252"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <Grid>
        <controls:MusicContentControl x:Name="MusicContent" />

        <!-- 贴边触发条（默认隐藏，Docked 状态时才可见） -->
        <controls:DockTriggerBar x:Name="DockTriggerBar"
            Width="14"
            VerticalAlignment="Stretch"
            Visibility="Collapsed" />
    </Grid>
</Window>