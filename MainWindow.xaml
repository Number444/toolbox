<Window x:Class="Toolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Toolbox.ViewModels"
        xmlns:m="clr-namespace:Toolbox.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:helpers="clr-namespace:Toolbox.Helpers"
        Title="🧰 Toolbox"
        Height="500" Width="780"
        MinHeight="400" MinWidth="600"
        WindowStartupLocation="CenterScreen"
        FontFamily="{StaticResource GlobalFont}"
        Background="Transparent"
        Foreground="{StaticResource TextPrimaryBrush}"
        ResizeMode="CanResizeWithGrip"
        WindowStyle="None"
        AllowsTransparency="False"
        UseLayoutRounding="True"
        SizeChanged="MainWindow_SizeChanged">

    <!-- 窗口圆角 + Mica 由代码后置 via Win32Helper -->

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0"
                      CornerRadius="8"
                      CaptionHeight="36"
                      ResizeBorderThickness="4"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- 遮盖四角的暗色块（堵住 DWM 帧扩展导致的四角漏白） -->
    <Grid>
        <Path x:Name="CornerMask"
              Fill="{StaticResource BgDarkBrush}"
              IsHitTestVisible="False"/>

        <!-- 外层 Border —— 强制裁剪内容为 Win11 圆角 -->
        <Border CornerRadius="8" ClipToBounds="True">

    <!-- ====== 主布局 ====== -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>   <!-- 标题栏 -->
            <RowDefinition Height="*"/>    <!-- 内容区 -->
            <RowDefinition Height="28"/>   <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ▸ 自定义标题栏（Mica 材质透入，含 Win11 风格三按钮） -->
        <Border Grid.Row="0"
                Background="{StaticResource BgDarkBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧标题 -->
                <TextBlock Text="🧰 Toolbox"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="14,0,0,0"/>

                <!-- 右侧窗口控制按钮 -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Stretch">
                    <!-- 最小化 -->
                    <Button x:Name="MinimizeButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource WindowButtonStyle}"
                            Click="MinimizeButton_Click">
                        <Path Data="M0,5 L10,5" Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="1.2" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                    <!-- 最大化/还原 -->
                    <Button x:Name="MaximizeButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource WindowButtonStyle}"
                            Click="MaximizeButton_Click">
                        <Grid Width="10" Height="10">
                            <Path x:Name="MaximizePath"
                                  Data="M0,0 L10,0 L10,10 L0,10 Z"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="1.2"/>
                            <Grid x:Name="RestorePath" Visibility="Collapsed">
                                <Path Data="M3,0 L10,0 L10,7 L3,7 Z"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                      StrokeThickness="1.2"/>
                                <Path Data="M0,3 L7,3 L7,10 L0,10 Z"
                                      Stroke="{StaticResource TextPrimaryBrush}"
                                      StrokeThickness="1.2"
                                      Fill="{StaticResource BgSurfaceBrush}"/>
                            </Grid>
                        </Grid>
                    </Button>
                    <!-- 关闭 -->
                    <Button x:Name="CloseButton"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Style="{StaticResource CloseButtonStyle}"
                            Click="CloseButton_Click">
                        <Path Data="M0,0 L10,10 M10,0 L0,10"
                              Stroke="{StaticResource TextPrimaryBrush}"
                              StrokeThickness="1.2" Width="10" Height="10" Stretch="Uniform"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ▸ 主体内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>   <!-- 左侧导航栏 -->
                <ColumnDefinition Width="1"/>     <!-- 分隔线 -->
                <ColumnDefinition Width="*"/>     <!-- 右侧内容区 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧导航（搜索框 + 手风琴分组 + 浮动高亮移动动画 + 自定义滚动条） -->
            <Border Grid.Column="0"
                    Background="{StaticResource BgSurfaceBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- 搜索框 -->
                        <RowDefinition Height="*"/>       <!-- 导航列表 -->
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 搜索框 -->
                    <Border Grid.Row="0" Grid.ColumnSpan="2"
                            Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🔍"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="4,0,6,0"/>
                            <Grid Grid.Column="1">
                                <!-- 输入框（提亮背景） -->
                                <TextBox x:Name="SearchInput"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="13"
                                         Height="28"
                                         VerticalContentAlignment="Center"
                                         Background="#404040"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         BorderThickness="0"
                                         Padding="6,0"
                                         KeyDown="SearchBox_KeyDown"
                                         PreviewMouseWheel="SearchBox_PreviewMouseWheel"/>
                                <!-- 占位符文字（输入为空时显示） -->
                                <TextBlock Text="  搜索工具"
                                           IsHitTestVisible="False"
                                           FontSize="13"
                                           Foreground="#777777"
                                           VerticalAlignment="Center"
                                           Padding="6,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=SearchInput}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- 导航列表 -->
                    <ScrollViewer x:Name="NavScrollViewer"
                                  Grid.Row="1" Grid.Column="0"
                                  VerticalScrollBarVisibility="Hidden">
                        <Grid x:Name="NavContainer" Margin="0,4,0,0">
                            <!-- 浮动高亮指示器（Grid 层绝对定位 → 不参与 ItemsControl 布局计算） -->
                            <Border x:Name="HighlightBar"
                                    Background="{StaticResource BgHoverBrush}"
                                    CornerRadius="6"
                                    Height="36"
                                    Margin="10,0,12,0"
                                    HorizontalAlignment="Stretch"
                                    VerticalAlignment="Top"
                                    Visibility="Collapsed">
                                <!-- 左侧高亮圆角竖线 (CornerRadius=半宽=1.5 → 两端圆角不变形) -->
                                <Border HorizontalAlignment="Left"
                                        Width="3"
                                        Height="16"
                                        CornerRadius="1.5"
                                        Margin="4,0,0,0"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource AccentBrush}"/>
                            </Border>

                            <!-- 分组列表 -->
                            <ItemsControl ItemsSource="{Binding VisibleGroups}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="m:ToolGroup">
                                        <StackPanel>
                                            <!-- 分类标题头（可点击折叠） -->
                                            <Border Padding="12,8"
                                                    Margin="6,2,8,1"
                                                    Cursor="Hand"
                                                    Height="38"
                                                    MouseLeftButtonDown="GroupHeader_MouseLeftButtonDown"
                                                    MouseEnter="GroupHeader_MouseEnter"
                                                    MouseLeave="GroupHeader_MouseLeave">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 图标/箭头切换：默认文件夹 📁，悬停时转箭头 ▾/▸（双 TextBlock + Visibility 消除文字跳变） -->
                                                    <Grid Width="20" Margin="0,0,6,0">
                                                        <!-- 文件夹图标（默认可见，悬停时隐藏） -->
                                                        <TextBlock Text="📁"
                                                                   FontSize="14"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <!-- 箭头图标（悬停时可见） -->
                                                        <TextBlock Text="{Binding ArrowText}"
                                                                   FontSize="16"
                                                                   TextAlignment="Center"
                                                                   VerticalAlignment="Center">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                    <!-- 分类名称（折叠后灰色，展开时正常色） -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding CategoryName}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>

                                            <!-- 该分类下的工具列表（外层 Border 用于展开/折叠 Height 动画） -->
                                            <Border ClipToBounds="True"
                                                    Height="0"
                                                    Tag="GroupAnimContainer">
                                                <ItemsControl ItemsSource="{Binding Tools}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- 左缩进 30px -->
                                                            <Border Padding="12,8"
                                                                    Margin="30,1,8,1"
                                                                    Cursor="Hand"
                                                                    Height="36"
                                                                    MouseLeftButtonDown="NavItem_MouseLeftButtonDown">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{Binding IconGlyph}"
                                                                               FontSize="13"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding Name}"
                                                                               FontSize="12"
                                                                               FontWeight="Normal"
                                                                               VerticalAlignment="Center"
                                                                               Margin="8,0,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>
                    <helpers:CustomScrollBar Grid.Row="1" Grid.Column="1"
                                             Width="8"
                                             TargetScrollViewer="{Binding ElementName=NavScrollViewer}"/>
                </Grid>
            </Border>

            <!-- 分隔线 -->
            <Border Grid.Column="1"
                    Background="{StaticResource BorderSubtleBrush}"
                    Width="1"/>

            <!-- 右侧内容区（带自定义滚动条） -->
            <Border Grid.Column="2"
                    Background="{StaticResource BgCardBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ScrollViewer x:Name="ContentScrollViewer"
                                  Grid.Column="0"
                                  VerticalScrollBarVisibility="Hidden"
                                  Padding="32,16">
                        <StackPanel>
                            <!-- 当前工具标题 -->
                            <TextBlock Text="{Binding SelectedToolName}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,4"/>

                            <!-- 当前工具描述 -->
                            <TextBlock Text="{Binding SelectedToolDescription}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- 分隔线 -->
                            <Rectangle Height="1"
                                       Fill="{StaticResource BorderSubtleBrush}"
                                       Margin="0,0,0,20"/>

                            <!-- 动态工具内容（带淡入过渡动画） -->
                            <helpers:TransitioningContentControl Content="{Binding CurrentContent}"/>
                        </StackPanel>
                    </ScrollViewer>
                    <helpers:CustomScrollBar Grid.Column="1"
                                             Width="8"
                                             TargetScrollViewer="{Binding ElementName=ContentScrollViewer}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ▸ 状态栏 -->
        <Border Grid.Row="2"
                Background="{StaticResource BgDarkBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="14,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center">
                    <Run Text="显示 "/>
                    <Run Text="{Binding VisibleToolCount, Mode=OneWay}"/>
                    <Run Text="/"/>
                    <Run Text="{Binding TotalToolCount, Mode=OneWay}"/>
                    <Run Text=" 个工具"/>
                </TextBlock>
                <TextBlock FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0">
                    v1.0
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Border>
</Grid>
</Window>